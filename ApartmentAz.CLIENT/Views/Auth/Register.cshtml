@model RegisterViewModel
@{
    var lang = (Context.Request.Query.TryGetValue("lang", out var ql) && !string.IsNullOrWhiteSpace(ql))
        ? ql.ToString()
        : (Context.Request.Cookies.TryGetValue("lang", out var cl) && !string.IsNullOrWhiteSpace(cl) ? cl : "az");
    ViewData["Title"] = L["Register", lang];
}

<div class="auth-wrapper">
    <div class="col-sm-11 col-md-8 col-lg-5">
        <div class="card auth-card">
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="auth-icon mx-auto mb-3">
                        <i class="bi bi-person-plus text-primary"></i>
                    </div>
                    <h4 class="fw-bold mb-1">@L["CreateAccount", lang]</h4>
                    <p class="text-muted small">@L["JoinApartmentAz", lang]</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 small mb-3"></div>
                }

                <form asp-action="Register" method="post">
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-medium">@L["FullName", lang]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="FullName" class="form-control" placeholder="John Doe" autocomplete="name" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium">@L["Email", lang]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-medium">@L["Phone", lang] <span class="text-muted fw-normal">(@L["Optional", lang])</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+994 50 000 00 00" autocomplete="tel" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-medium">@L["Password", lang]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" type="password" id="regPassword" placeholder="Min. 6 characters" autocomplete="new-password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePw('regPassword', this)" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-medium">@L["ConfirmPassword", lang]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" id="regConfirm" placeholder="Repeat password" autocomplete="new-password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePw('regConfirm', this)" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100 py-2">
                        <i class="bi bi-person-check me-1"></i> @L["CreateAccount", lang]
                    </button>
                </form>

                <hr class="my-3" />
                <p class="text-center mb-0 small">
                    @L["AlreadyHaveAccount", lang]
                    <a asp-action="Login" asp-route-lang="@lang" class="fw-semibold text-gradient text-decoration-none">@L["SignIn", lang]</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePw(id, btn) {
            const input = document.getElementById(id);
            const icon = btn.querySelector('i');
            if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye-slash'; }
            else { input.type = 'password'; icon.className = 'bi bi-eye'; }
        }
    </script>
}
