@model LoginViewModel
@{
    var lang = (Context.Request.Query.TryGetValue("lang", out var ql) && !string.IsNullOrWhiteSpace(ql))
        ? ql.ToString()
        : (Context.Request.Cookies.TryGetValue("lang", out var cl) && !string.IsNullOrWhiteSpace(cl) ? cl : "az");
    ViewData["Title"] = L["Login", lang];
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="auth-wrapper">
    <div class="col-sm-11 col-md-7 col-lg-4">
        <div class="card auth-card">
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="auth-icon mx-auto mb-3">
                        <i class="bi bi-buildings text-primary"></i>
                    </div>
                    <h4 class="fw-bold mb-1">@L["WelcomeBack", lang]</h4>
                    <p class="text-muted small">@L["SignInToYourAccount", lang]</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 small mb-3"></div>
                }

                <form asp-action="Login" method="post" asp-route-returnUrl="@returnUrl">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium">@L["Email", lang]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-medium">@L["Password", lang]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" type="password" id="loginPassword" placeholder="••••••••" autocomplete="current-password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePw('loginPassword', this)" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">@L["RememberMe", lang]</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-box-arrow-in-right me-1"></i> @L["SignIn", lang]
                    </button>
                </form>

                <hr class="my-3" />
                <p class="text-center mb-0 small">
                    @L["DontHaveAnAccount", lang]
                    <a asp-action="Register" asp-route-lang="@lang" class="fw-semibold text-gradient text-decoration-none">@L["CreateOne", lang]</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePw(id, btn) {
            const input = document.getElementById(id);
            const icon = btn.querySelector('i');
            if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye-slash'; }
            else { input.type = 'password'; icon.className = 'bi bi-eye'; }
        }
    </script>
}
