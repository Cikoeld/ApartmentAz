@model List<ApartmentAz.CLIENT.Services.ChatConversationApiModel>
@{
    ViewData["Title"] = "Messages";
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="bi bi-chat-dots"></i> Messages</h2>
        <hr />
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-chat-square-text display-1"></i>
        <h4 class="mt-3">No conversations yet</h4>
        <p>Start a conversation by visiting a listing and clicking "Contact Owner".</p>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var convo in Model)
        {
            <a asp-action="Room"
               asp-route-otherUserId="@convo.OtherUserId"
               asp-route-listingId="@convo.ListingId"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1">
                        <i class="bi bi-person-circle"></i> @convo.OtherUserName
                    </h6>
                    <p class="mb-0 text-muted small">@convo.LastMessage</p>
                </div>
                <small class="text-muted">@convo.LastMessageAt.ToString("dd MMM HH:mm")</small>
            </a>
        }
    </div>
}
