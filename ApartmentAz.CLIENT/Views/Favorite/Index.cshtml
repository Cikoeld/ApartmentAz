@model List<FavoriteViewModel>
@{
    var lang = (Context.Request.Query.TryGetValue("lang", out var ql) && !string.IsNullOrWhiteSpace(ql))
        ? ql.ToString()
        : (Context.Request.Cookies.TryGetValue("lang", out var cl) && !string.IsNullOrWhiteSpace(cl) ? cl : "az");
    ViewData["Title"] = L["MyFavorites", lang];
}

<div class="favorites-header d-flex align-items-center justify-content-between">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-heart-fill text-danger me-2"></i>@L["MyFavorites", lang]</h3>
        <p class="text-muted small mb-0">@Model.Count @(Model.Count != 1 ? L["Listings", lang] : L["Listing", lang]) saved</p>
    </div>
    <a asp-controller="Home" asp-action="Index" asp-route-lang="@lang" class="btn btn-gradient px-3">
        <i class="bi bi-search me-1"></i> @L["BrowseListings", lang]
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-heart text-muted" style="font-size:4rem;opacity:.3;"></i>
        <h5 class="mt-3 text-muted">@L["NoSavedListings", lang]</h5>
        <p class="text-muted small">@L["BrowseListingsHint", lang]</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col" id="fav-col-@item.ListingId">
                <div class="card card-listing h-100">
                    <div class="card-img-wrap">
                        @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                        {
                            <img src="@item.ThumbnailUrl" class="card-img-top" alt="@item.Title" />
                        }
                        else
                        {
                            <div class="img-placeholder">
                                <i class="bi bi-buildings text-secondary" style="font-size:3rem;opacity:.35;"></i>
                            </div>
                        }
                        <button class="card-fav-btn active"
                                onclick="removeFavorite('@item.ListingId', this)"
                                title="@L["RemoveFromFavorites", lang]">
                            <i class="bi bi-heart-fill"></i>
                        </button>
                    </div>
                    <a asp-controller="Listing" asp-action="Details" asp-route-id="@item.ListingId" asp-route-lang="@lang"
                       class="text-decoration-none text-reset">
                        <div class="card-body">
                            <h6 class="card-title text-truncate" title="@item.Title">@item.Title</h6>
                            @if (!string.IsNullOrEmpty(item.CityName))
                            {
                                <p class="card-location mb-2">
                                    <i class="bi bi-geo-alt-fill"></i> @item.CityName
                                </p>
                            }
                            <div class="d-flex justify-content-between align-items-end">
                                <span class="card-price">@item.Price.ToString("N0") ₼</span>
                                <span class="card-meta">
                                    <span><i class="bi bi-door-open"></i> @item.RoomCount</span>
                                    <span><i class="bi bi-aspect-ratio"></i> @item.Area m²</span>
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        async function removeFavorite(listingId, btn) {
            const res = await fetch(`/Favorite/Toggle?listingId=${listingId}&isFavorite=true`, { method: 'POST' });
            if (res.ok) {
                const col = document.getElementById(`fav-col-${listingId}`);
                col.style.transition = 'opacity .3s, transform .3s';
                col.style.opacity = '0';
                col.style.transform = 'scale(.92)';
                setTimeout(() => {
                    col.remove();
                    const remaining = document.querySelectorAll('.card-listing').length;
                    if (remaining === 0) location.reload();
                }, 300);
            }
        }
    </script>
}
