@model List<FavoriteViewModel>
@{
    ViewData["Title"] = L["MyFavorites", "en"];
    var lang = (Context.Request.Query.TryGetValue("lang", out var ql) && !string.IsNullOrWhiteSpace(ql))
        ? ql.ToString()
        : (Context.Request.Cookies.TryGetValue("lang", out var cl) && !string.IsNullOrWhiteSpace(cl) ? cl : "az");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h3 class="mb-0"><i class="bi bi-heart-fill text-danger me-2"></i>@L["MyFavorites", lang]</h3>
    <span class="badge bg-secondary fs-6">@Model.Count @(Model.Count != 1 ? L["Listings", lang] : L["Listing", lang])</span>
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-heart text-muted" style="font-size:4rem;"></i>
        <h5 class="mt-3 text-muted">@L["NoSavedListings", lang]</h5>
        <p class="text-muted small">@L["BrowseListingsHint", lang]</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
            <i class="bi bi-search"></i> @L["BrowseListings", lang]
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card card-listing h-100">
                    @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                    {
                        <img src="@item.ThumbnailUrl" class="card-img-top" style="height:190px;object-fit:cover;" alt="@item.Title" />
                    }
                    else
                    {
                        <div class="card-img-top bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center" style="height:190px;">
                            <i class="bi bi-image text-secondary" style="font-size:3rem;"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h6 class="card-title mb-1 text-truncate" title="@item.Title">@item.Title</h6>
                        @if (!string.IsNullOrEmpty(item.CityName))
                        {
                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt"></i> @item.CityName
                            </p>
                        }
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-bold text-primary fs-5">@item.Price.ToString("N0") ₼</span>
                            <span class="badge bg-secondary">@item.RoomCount @L["Room", lang] · @item.Area m²</span>
                        </div>
                    </div>
                    <div class="card-footer border-0 d-flex gap-2">
                        <a asp-controller="Listing" asp-action="Details" asp-route-id="@item.ListingId"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="bi bi-eye"></i> @L["Details", lang]
                        </a>
                        <button class="btn btn-danger btn-sm" onclick="removeFavorite('@item.ListingId', this)"
                                title="@L["RemoveFromFavorites", lang]">
                            <i class="bi bi-heart-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        async function removeFavorite(listingId, btn) {
            const res = await fetch(`/Favorite/Toggle?listingId=${listingId}&isFavorite=true`, { method: 'POST' });
            if (res.ok) btn.closest('.col').remove();
        }
    </script>
}
