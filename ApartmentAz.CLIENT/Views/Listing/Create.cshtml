@model CreateListingViewModel
@{
    var lang = (Context.Request.Query.TryGetValue("lang", out var ql) && !string.IsNullOrWhiteSpace(ql))
        ? ql.ToString()
        : (Context.Request.Cookies.TryGetValue("lang", out var cl) && !string.IsNullOrWhiteSpace(cl) ? cl : "az");
    ViewData["Title"] = L["CreateNewListing", lang];
}

<div class="mb-4">
    <h3 class="fw-bold"><i class="bi bi-plus-circle text-gradient"></i> @L["CreateNewListing", lang]</h3>
    <p class="text-muted small mb-0">@L["AutoTranslateHint", lang]</p>
</div>

<form asp-action="Create" asp-controller="Listing" method="post" enctype="multipart/form-data">
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3"></div>
    }
    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Title & Description -->
            <div class="create-card mb-4">
                <div class="card-header"><i class="bi bi-translate me-2"></i>@L["Translations", lang]</div>
                <div class="card-body p-3">
                    <label class="form-label fw-medium">@L["Title", lang]</label>
                    <input asp-for="Title" class="form-control mb-3" />
                    <label class="form-label fw-medium">@L["DescriptionLabel", lang]</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
            </div>

            <!-- Core Info -->
            <div class="create-card mb-4">
                <div class="card-header"><i class="bi bi-house-gear me-2"></i>@L["PropertyInfo", lang]</div>
                <div class="card-body p-3">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-medium">@L["PriceAZN", lang]</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">@L["RoomCount", lang]</label>
                            <input asp-for="RoomCount" class="form-control" type="number" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">@L["AreaM2", lang]</label>
                            <input asp-for="Area" class="form-control" type="number" step="0.1" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">@L["Floor", lang]</label>
                            <input asp-for="Floor" class="form-control" type="number" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">@L["TotalFloors", lang]</label>
                            <input asp-for="TotalFloors" class="form-control" type="number" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end gap-3">
                            <div class="form-check">
                                <input asp-for="HasDocument" class="form-check-input" />
                                <label class="form-check-label">@L["Document", lang]</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="HasMortgage" class="form-check-input" />
                                <label class="form-check-label">@L["Mortgage", lang]</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact -->
            <div class="create-card mb-4">
                <div class="card-header"><i class="bi bi-person me-2"></i>@L["ContactInfo", lang]</div>
                <div class="card-body p-3">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <input asp-for="Name" class="form-control" placeholder="@L["Name", lang]" />
                        </div>
                        <div class="col-md-4">
                            <input asp-for="Email" class="form-control" placeholder="@L["Email", lang]" type="email" />
                        </div>
                        <div class="col-md-4">
                            <input asp-for="Phone" class="form-control" placeholder="@L["Phone", lang]" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Images -->
            <div class="create-card mb-4">
                <div class="card-header"><i class="bi bi-images me-2"></i>@L["Images", lang]</div>
                <div class="card-body p-3">
                    <input asp-for="Images" id="imageInput" class="form-control" type="file" multiple accept="image/*" />
                    <div id="imagePreviewGrid"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Enums -->
            <div class="create-card mb-4">
                <div class="card-header"><i class="bi bi-tags me-2"></i>@L["Type", lang]</div>
                <div class="card-body p-3">
                    <label class="form-label fw-medium">@L["ListingType", lang]</label>
                    <select asp-for="ListingType" class="form-select mb-2">
                        <option value="1">@L["Sale", lang]</option>
                        <option value="2">@L["Rent", lang]</option>
                    </select>
                    <label class="form-label fw-medium">@L["RentType", lang]</label>
                    <select asp-for="RentType" class="form-select mb-2">
                        <option value="">—</option>
                        <option value="1">@L["Monthly", lang]</option>
                        <option value="2">@L["Daily", lang]</option>
                    </select>
                    <label class="form-label fw-medium">@L["PropertyType", lang]</label>
                    <select asp-for="PropertyType" id="propertyTypeSelect" class="form-select mb-2">
                        <option value="1">@L["NewBuilding", lang]</option>
                        <option value="2">@L["OldBuilding", lang]</option>
                        <option value="3">@L["House", lang]</option>
                        <option value="4">@L["Office", lang]</option>
                        <option value="5">@L["Garage", lang]</option>
                        <option value="6">@L["Land", lang]</option>
                        <option value="7">@L["Commercial", lang]</option>
                    </select>
                    <label class="form-label fw-medium">@L["SellerType", lang]</label>
                    <select asp-for="SellerType" class="form-select mb-2">
                        <option value="1">@L["Owner", lang]</option>
                        <option value="2">@L["Agent", lang]</option>
                    </select>
                    <label class="form-label fw-medium">@L["RepairStatus", lang]</label>
                    <select asp-for="RepairStatus" class="form-select">
                        <option value="0">@L["None", lang]</option>
                        <option value="1">@L["Repaired", lang]</option>
                        <option value="2">@L["NotRepaired", lang]</option>
                    </select>
                </div>
            </div>

            <!-- Location -->
            <div class="create-card mb-4">
                <div class="card-header"><i class="bi bi-geo-alt me-2"></i>@L["Location", lang]</div>
                <div class="card-body p-3">
                    <select asp-for="CityId" id="createCitySelect" class="form-select mb-2">
                        <option value="">@L["SelectCity", lang]</option>
                        @foreach (var c in Model.Cities) { <option value="@c.Id">@c.Name</option> }
                    </select>
                    <select asp-for="DistrictId" id="createDistrictSelect" class="form-select mb-2">
                        <option value="">@L["SelectDistrict", lang]</option>
                    </select>
                    <select asp-for="MetroId" id="createMetroSelect" class="form-select">
                        <option value="">@L["SelectMetro", lang]</option>
                    </select>
                </div>
            </div>

            <!-- Optional -->
            <div class="create-card mb-4">
                <div class="card-header"><i class="bi bi-sliders me-2"></i>@L["Optional", lang]</div>
                <div class="card-body p-3">
                    <label class="form-label fw-medium">@L["Agency", lang]</label>
                    <select asp-for="AgencyId" class="form-select mb-2">
                        <option value="">@L["None", lang]</option>
                        @foreach (var a in Model.Agencies) { <option value="@a.Id">@a.Name</option> }
                    </select>
                    <label class="form-label fw-medium">@L["ResidentialComplex", lang]</label>
                    <select asp-for="ResidentialComplexId" class="form-select">
                        <option value="">@L["None", lang]</option>
                        @foreach (var rc in Model.ResidentialComplexes) { <option value="@rc.Id">@rc.Name</option> }
                    </select>
                </div>
            </div>

            <!-- Commercial Detail -->
            <div class="create-card mb-4" id="commercialCard" style="display:none;">
                <div class="card-header"><i class="bi bi-shop me-2"></i>@L["CommercialDetails", lang]</div>
                <div class="card-body p-3">
                    <div class="form-check mb-2"><input asp-for="HasParking" class="form-check-input" /><label class="form-check-label">@L["Parking", lang]</label></div>
                    <div class="form-check mb-2"><input asp-for="HasHeating" class="form-check-input" /><label class="form-check-label">@L["Heating", lang]</label></div>
                    <div class="form-check"><input asp-for="HasAirConditioner" class="form-check-input" /><label class="form-check-label">@L["AirConditioner", lang]</label></div>
                </div>
            </div>

            <button type="submit" id="submitBtn" class="btn btn-gradient w-100 py-2">
                <span id="submitLabel"><i class="bi bi-check-circle me-1"></i> @L["CreateListing", lang]</span>
                <span id="submitSpinner" class="d-none">
                    <span class="spinner-border spinner-border-sm me-1"></span> @L["Saving", lang]...
                </span>
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const createCity = document.getElementById('createCitySelect');
        const createDistrict = document.getElementById('createDistrictSelect');
        const createMetro = document.getElementById('createMetroSelect');
        const propType = document.getElementById('propertyTypeSelect');
        const commercialCard = document.getElementById('commercialCard');
        function getCookieLang() { const m = document.cookie.match(/(?:^|;\s*)lang=([^;]*)/); return m ? m[1] : 'az'; }
        const lang = getCookieLang();

        createCity?.addEventListener('change', async function () {
            const cityId = this.value;
            createDistrict.innerHTML = '<option value="">@L["SelectDistrict", lang]</option>';
            createMetro.innerHTML = '<option value="">@L["SelectMetro", lang]</option>';
            if (!cityId) return;
            const [districts, metros] = await Promise.all([
                fetch(`/Home/GetDistricts?cityId=${cityId}&lang=${lang}`).then(r => r.json()),
                fetch(`/Home/GetMetros?cityId=${cityId}&lang=${lang}`).then(r => r.json())
            ]);
            districts.forEach(d => { const o = document.createElement('option'); o.value = d.id; o.textContent = d.name; createDistrict.appendChild(o); });
            metros.forEach(m => { const o = document.createElement('option'); o.value = m.id; o.textContent = m.name; createMetro.appendChild(o); });
        });
        propType?.addEventListener('change', function () { commercialCard.style.display = this.value === '7' ? 'block' : 'none'; });
        document.getElementById('imageInput')?.addEventListener('change', function () {
            const grid = document.getElementById('imagePreviewGrid'); grid.innerHTML = '';
            [...this.files].forEach(file => { const reader = new FileReader(); reader.onload = e => { const img = document.createElement('img'); img.src = e.target.result; grid.appendChild(img); }; reader.readAsDataURL(file); });
        });
        document.querySelector('form')?.addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn'); btn.disabled = true;
            document.getElementById('submitLabel').classList.add('d-none'); document.getElementById('submitSpinner').classList.remove('d-none');
        });
    </script>
}
