@model List<ApartmentAz.CLIENT.Services.AdminUserApiModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-people"></i> User Management</h3>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
</div>

<div id="statusAlert" class="alert d-none" role="alert"></div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Roles</th>
                <th>Status</th>
                <th style="width:280px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr id="user-@user.Id">
                    <td id="name-@user.Id">@user.FullName</td>
                    <td id="email-@user.Id">@user.Email</td>
                    <td id="phone-@user.Id">@(user.PhoneNumber ?? "—")</td>
                    <td>
                        @foreach (var role in user.Roles)
                        {
                            <span class="badge @(role == "Admin" ? "bg-primary" : "bg-secondary")">@role</span>
                        }
                    </td>
                    <td>
                        @if (user.IsBanned)
                        {
                            <span class="badge bg-danger" id="status-@user.Id">Banned</span>
                        }
                        else
                        {
                            <span class="badge bg-success" id="status-@user.Id">Active</span>
                        }
                    </td>
                    <td>
                        @if (!user.Roles.Contains("Admin"))
                        {
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" onclick="openEditUser('@user.Id', '@user.FullName.Replace("'", "\\'")','@user.Email.Replace("'", "\\'")','@(user.PhoneNumber?.Replace("'", "\\'") ?? "")')">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                @if (user.IsBanned)
                                {
                                    <button class="btn btn-outline-success" id="ban-btn-@user.Id"
                                            onclick="unbanUser('@user.Id')">
                                        <i class="bi bi-unlock"></i> Unban
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-warning" id="ban-btn-@user.Id"
                                            onclick="banUser('@user.Id')">
                                        <i class="bi bi-lock"></i> Ban
                                    </button>
                                }
                                <button class="btn btn-outline-danger" onclick="deleteUser('@user.Id')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        }
                        else
                        {
                            <span class="text-muted small">Protected</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-gear"></i> Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editUserId" />
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-control" id="editFullName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" id="editEmail" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone Number</label>
                    <input type="text" class="form-control" id="editPhone" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveUserEdit()">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showAlert(msg, type) {
        const el = document.getElementById('statusAlert');
        el.className = `alert alert-${type}`;
        el.textContent = msg;
        el.classList.remove('d-none');
        setTimeout(() => el.classList.add('d-none'), 3000);
    }

    function openEditUser(id, fullName, email, phone) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editFullName').value = fullName;
        document.getElementById('editEmail').value = email;
        document.getElementById('editPhone').value = phone;
        new bootstrap.Modal(document.getElementById('editUserModal')).show();
    }

    async function saveUserEdit() {
        const id = document.getElementById('editUserId').value;
        const body = {
            fullName: document.getElementById('editFullName').value,
            email: document.getElementById('editEmail').value,
            phoneNumber: document.getElementById('editPhone').value || null
        };
        const res = await fetch(`/Admin/UpdateUser?id=${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
            document.getElementById(`name-${id}`).textContent = body.fullName;
            document.getElementById(`email-${id}`).textContent = body.email;
            document.getElementById(`phone-${id}`).textContent = body.phoneNumber || '—';
            showAlert('User updated!', 'success');
        } else {
            showAlert('Failed to update user.', 'danger');
        }
    }

    async function banUser(id) {
        const res = await fetch(`/Admin/BanUser?id=${id}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            const badge = document.getElementById(`status-${id}`);
            badge.className = 'badge bg-danger';
            badge.textContent = 'Banned';
            const btn = document.getElementById(`ban-btn-${id}`);
            btn.className = 'btn btn-outline-success btn-sm';
            btn.innerHTML = '<i class="bi bi-unlock"></i> Unban';
            btn.setAttribute('onclick', `unbanUser('${id}')`);
            showAlert('User banned.', 'warning');
        } else {
            showAlert('Failed to ban user.', 'danger');
        }
    }

    async function unbanUser(id) {
        const res = await fetch(`/Admin/UnbanUser?id=${id}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            const badge = document.getElementById(`status-${id}`);
            badge.className = 'badge bg-success';
            badge.textContent = 'Active';
            const btn = document.getElementById(`ban-btn-${id}`);
            btn.className = 'btn btn-outline-warning btn-sm';
            btn.innerHTML = '<i class="bi bi-lock"></i> Ban';
            btn.setAttribute('onclick', `banUser('${id}')`);
            showAlert('User unbanned.', 'success');
        } else {
            showAlert('Failed to unban user.', 'danger');
        }
    }

    async function deleteUser(id) {
        if (!confirm('Delete this user permanently?')) return;
        const res = await fetch(`/Admin/DeleteUser?id=${id}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            document.getElementById(`user-${id}`).remove();
            showAlert('User deleted.', 'success');
        } else {
            showAlert('Failed to delete user.', 'danger');
        }
    }
</script>
}
