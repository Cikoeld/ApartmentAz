<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ApartmentAz</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function () {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>
</head>
<body>
    <nav class="navbar navbar-expand-lg" id="mainNav">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-buildings"></i> ApartmentAz
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                @{
                    var currentLang = (Context.Request.Query.TryGetValue("lang", out var ql) && !string.IsNullOrWhiteSpace(ql))
                        ? ql.ToString()
                        : (Context.Request.Cookies.TryGetValue("lang", out var cl) && !string.IsNullOrWhiteSpace(cl) ? cl : "az");
                }
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index" asp-route-lang="@currentLang">
                            <i class="bi bi-house"></i> @L["Home", currentLang]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Listing" asp-action="Create" asp-route-lang="@currentLang">
                            <i class="bi bi-plus-circle"></i> @L["CreateListing", currentLang]
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Favorite" asp-action="Index" asp-route-lang="@currentLang">
                                <i class="bi bi-heart"></i> @L["Favorites", currentLang]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Chat" asp-action="Index">
                                <i class="bi bi-chat-dots"></i> Messages
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-shield-lock"></i> @L["AdminPanel", currentLang]
                                </a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav align-items-center gap-1">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-globe"></i> @currentLang.ToUpper()
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item @(currentLang == "az" ? "active" : "")" href="javascript:void(0)" onclick="switchLang('az')">🇦🇿 Azərbaycan</a></li>
                            <li><a class="dropdown-item @(currentLang == "en" ? "active" : "")" href="javascript:void(0)" onclick="switchLang('en')">🇬🇧 English</a></li>
                            <li><a class="dropdown-item @(currentLang == "ru" ? "active" : "")" href="javascript:void(0)" onclick="switchLang('ru')">🇷🇺 Русский</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-sm nav-link border-0 px-2" id="themeToggle" onclick="toggleTheme()" title="Toggle theme">
                            <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                        </button>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> @L["Logout", currentLang]
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-sm btn-gradient px-3" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-person"></i> @L["Login", currentLang]
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        <main>
            @RenderBody()
        </main>
    </div>

    <footer class="border-top py-4 mt-auto">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span class="text-muted small">
                <span class="text-gradient fw-bold">ApartmentAz</span> &copy; 2026 &mdash; All rights reserved
            </span>
            <span class="text-muted small d-flex gap-3">
                <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">
                    <i class="bi bi-house"></i> @L["Home", currentLang]
                </a>
                <a asp-controller="Auth" asp-action="Login" class="text-muted text-decoration-none">
                    <i class="bi bi-person"></i> @L["Login", currentLang]
                </a>
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function switchLang(lang) {
            document.cookie = `lang=${lang};path=/;max-age=${365 * 24 * 3600}`;
            const url = new URL(window.location.href);
            url.searchParams.set('lang', lang);
            window.location.href = url.toString();
        }
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
